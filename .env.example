# ─── NextAuth ───────────────────────────────────────────────
NEXTAUTH_SECRET=replace_with_a_random_secret_string
NEXTAUTH_URL=http://localhost:3000

# ─── Django Backend ─────────────────────────────────────────
DJANGO_URL=http://localhost:8000
# Must match SECRET_KEY in backend/.env exactly
DJANGO_SECRET_KEY=replace_with_your_django_secret_key

# ─── MySQL Database ─────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=games_dictionary

# ─── Admin Account ──────────────────────────────────────────
# Generate hash: node -e "const b=require('bcryptjs');b.hash('yourpassword',10).then(console.log)"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here

# ─── Email (Gmail SMTP) ──────────────────────────────────────
# Use a Gmail App Password, NOT your regular Gmail password
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─── OpenRouter AI ───────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here
